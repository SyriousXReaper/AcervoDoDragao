@model BibliotecaMVC.Models.Livro

<h1>@Model.Titulo</h1>

<img src="@Model.Capa" style="width:250px">

<p><b>Descrição:</b> @Model.Descricao</p>

<p><b>Ano:</b> @Model.Ano</p>

<p>
<b>Autor:</b>

    <a asp-controller="Autor"
       asp-action="Detalhes"
       asp-route-id="@Model.AutorId">

        @Model.Autor.Nome
    </a>

</p>